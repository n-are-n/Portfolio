!!!
%html(lang="en")
    %head
        %meta(charset="UTF-8")
        %meta(content="IE=edge" http-equiv="X-UA-Compatible")
        %meta(content="width=device-width, initial-scale=1.0" name="viewport")
        %title Naren
        %link(rel="stylesheet" href="../styl/style.styl")
        %script(src="../ts/script.ts")
    %body
        -# Header
        %header
            -# Logo
            %span
                %a.nav_logo(href="#") Naren
            -# Navbar
            %nav
                %ul.nav_list
                    %li.nav_item
                        %a.nav_link(href="#Home") Home
                    %li.nav_item
                        %a.nav_link(href="#About") About
                    %li.nav_item
                        %a.nav_link(href="Skills") Skills
                    %li.nav_item
                        %a.nav_link(href="#Work") Work
                    %li.nav_item
                        %a.nav_link(href="#Contact") Contact
                %span.nav_toggle#nav-toggle
                    %i
        %main.l-main
            -# Home
            %section#Home.home.bd-grid
                .home_data
                    %h6.home_title Hi, 
                        %br I'm 
                        %sapn.home_title-color Naren 
                        %br Web Developer
                    %a.button(href="#Contact")
                        %button Contact
                %ol.home_social
                    %a.home_social-icon(href="")
                        %i
                    %a.home_social-icon(href="")
                        %i
                    %a.home_social-icon(href="")
                        %i
                %figure.home_img
                    %svg.home__blob(viewBox="0 0 479 467" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink")
                        %mask#mask0(mask-type="alpha")
                            %path(d="M9.19024 145.964C34.0253 76.5814 114.865 54.7299 184.111 29.4823C245.804 6.98884 311.86 -14.9503 370.735 14.143C431.207 44.026 467.948 107.508 477.191 174.311C485.897 237.229 454.931 294.377 416.506 344.954C373.74 401.245 326.068 462.801 255.442 466.189C179.416 469.835 111.552 422.137 65.1576 361.805C17.4835 299.81 -17.1617 219.583 9.19024 145.964Z")
                        %g(mask="url(#mask0)")
                            %path(d="M9.19024 145.964C34.0253 76.5814 114.865 54.7299 184.111 29.4823C245.804 6.98884 311.86 -14.9503 370.735 14.143C431.207 44.026 467.948 107.508 477.191 174.311C485.897 237.229 454.931 294.377 416.506 344.954C373.74 401.245 326.068 462.801 255.442 466.189C179.416 469.835 111.552 422.137 65.1576 361.805C17.4835 299.81 -17.1617 219.583 9.19024 145.964Z")
                            %img.home_blob-img(href="../img/perfil.png" x="50" y="60")
            -# About
            %section#About.about.section
                %h6.section-title About
                .about_container.bd-grid
                    %figure.about_img
                        %img(alt="" src="../img/about.jpg")
                    %h5.about_subtitle I'm Naren
                    %p.about_text Lorem, ipsum dolor sit amet consectetur adipisicing elit. Voluptate cum expedita quo culpa tempora, assumenda, quis fugiat ut voluptates soluta, aut earum nemo recusandae cumque perferendis! Recusandae alias accusamus atque.
            -# Skills
            %section#Skills.skills.section
                %h5.section-title Skills
                .skills_container.bd-grid
                    %h6.skills_subtitle Professional Skills
                    %p.skills_text Lorem ipsum dolor sit, amet consectetur adipisicing elit. Velit optio id vero amet, alias architecto consectetur error eum eaque sit.
                    %figure
                        %img
            -# Work
            %section#Work.work.section
                %h6.section-title Work
                .work_container.bd-grid
                    %a.work_img(href="")
                        %figure
                            %img(alt="" src="../img/work1.jpg")
                    %a.work_img(href="")
                        %figure
                            %img(alt="" src="../img/work2.jpg")
                    %a.work_img(href="")
                        %figure
                            %img(alt="" src="../img/work3.jpg")
                    %a.work_img(href="")
                        %figure
                            %img(alt="" src="../img/work4.jpg")
                    %a.work_img(href="")
                        %figure
                            %img(alt="" src="../img/work5.jpg")
                    %a.work_img(href="")
                        %figure
                            %img(alt="" src="../img/work6.jpg")
            -# Contact
            %section#Contact.contact.section
                %form.contact_form(action="" enctype="Multipart/form-data" method="POST")
                    %legend.sction-title Contact
                    %input.contact_input(type="text" placeholder="Name")
                    %input.contact_input(type="email" placeholder="Mail")
                    %textarea.contact_input(cols=0 rows=10)
                    %input.button.contact_button(type="submit" placeholder="Submit")
        -# Footer
        %footer.footer
            %h1.footer_title Naren
            .footer_social
                %a.footer_icon(href="#")
                    %i
                %a.footer_icon(href="#")
                    %i
                %a.footer_icon(href="#")
                    %i
            %p.footer_copy &#169; All rights reserved